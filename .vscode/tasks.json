{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build active file",
            "command": "/usr/bin/g++",
            "args": [
                "-g3",
                "-lrt",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/gfx/Display.cpp",
                "${workspaceFolder}/gfx/UiManager.cpp",
                "${workspaceFolder}/gfx/ui/UiObject.cpp",
                "${workspaceFolder}/gfx/ui/Image.cpp",
                "${workspaceFolder}/gfx/ui/ProgressBar.cpp",
                "${workspaceFolder}/gfx/ui/Text.cpp",
                "${workspaceFolder}/gfx/bitmapfont/Font.cpp",
                "-pthread",
                "-o",
                "${fileDirname}/a.out"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}